{%- style -%}
  .testimonials {
    background-color: #E8DFC8;
    padding: 8rem 0;
  }

  .testimonials__heading {
    font-family: var(--pw-font-heading);
    color: var(--pw-primary);
    font-size: 4rem;
    text-align: center;
    margin-bottom: 5rem;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .testimonial-card {
    background: #ffffff;
    padding: 4rem 3rem;
    border-radius: 12px;
    text-align: center;
    transition: all 0.4s ease;
    box-shadow: 0 10px 30px rgba(35, 78, 63, 0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .testimonial__photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: #F8F6F1;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #C9A227;
  }

  .testimonial__photo svg {
    width: 40px;
    height: 40px;
    color: #C9A227;
  }

  .testimonial__rating {
    margin-bottom: 1.5rem;
    color: #C9A227;
    font-size: 2rem;
  }

  .testimonial__text {
    font-family: var(--pw-font-body);
    color: #222222;
    font-size: 1.6rem;
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 2.5rem;
  }

  .testimonial__author {
    font-family: var(--pw-font-heading);
    color: var(--pw-primary);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .testimonial__badge {
    font-family: var(--pw-font-body);
    color: #C9A227;
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .testimonial__badge svg {
    width: 14px;
    height: 14px;
  }

  @media screen and (max-width: 989px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media screen and (max-width: 749px) {
    .testimonials {
      padding: 5rem 0;
    }
    .testimonials__heading {
      font-size: 3rem;
      margin-bottom: 3rem;
    }
  }
{%- endstyle -%}

