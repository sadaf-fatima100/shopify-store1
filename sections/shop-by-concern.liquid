{%- style -%}
  .shop-by-concern {
    background-color: #ffffff;
    padding: 8rem 0;
  }

  .concern__heading {
    font-family: var(--pw-font-heading);
    color: var(--pw-primary);
    font-size: 4rem;
    text-align: center;
    margin-bottom: 5rem;
  }

  .concern__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .concern-card {
    background-color: #234E3F;
    padding: 5rem 3rem;
    border-radius: 12px;
    text-align: center;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
  }

  .concern-card svg {
    width: 40px;
    height: 40px;
    color: #C9A227;
    margin-bottom: 2rem;
    transition: color 0.4s ease;
  }

  .concern-card h3 {
    font-family: var(--pw-font-heading);
    color: #ffffff;
    font-size: 2.4rem;
    margin: 0;
    transition: color 0.4s ease;
  }

  .concern-card:hover {
    background-color: #C9A227;
    transform: translateY(-5px);
  }

  .concern-card:hover svg,
  .concern-card:hover h3 {
    color: #222222;
  }

  @media screen and (max-width: 989px) {
    .concern__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .shop-by-concern {
      padding: 5rem 0;
    }
    .concern__heading {
      font-size: 3rem;
      margin-bottom: 3rem;
    }
    .concern__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
{%- endstyle -%}

