{%- style -%}
  #Banner-{{ section.id }} {
    background-color: #234E3F;
    background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 20c0 10 10 20 20 20s20-10 20-20-10-20-20-20-20 10-20 20zm50 40c0 10 10 20 20 20s20-10 20-20-10-20-20-20-20 10-20 20zM0 80c0 10 10 20 20 20s20-10 20-20-10-20-20-20-20 10-20 20z' fill='%23E8DFC8' fill-opacity='0.03'/%3E%3C/svg%3E");
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  #Banner-{{ section.id }} .banner__box {
    background: transparent !important;
    text-align: center;
    max-width: 80rem;
    margin: 0 auto;
  }

  #Banner-{{ section.id }} .banner__heading {
    font-family: var(--pw-font-heading) !important;
    color: var(--pw-accent) !important;
    font-size: 6rem !important;
    line-height: 1.1;
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInLift 1s ease forwards 0.3s;
  }

  #Banner-{{ section.id }} .banner__text {
    font-family: var(--pw-font-body) !important;
    color: var(--pw-secondary) !important;
    font-size: 2rem !important;
    line-height: 1.6;
    margin-bottom: 4rem;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInLift 1s ease forwards 0.6s;
  }

  #Banner-{{ section.id }} .banner__buttons {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInLift 1s ease forwards 0.9s;
    display: flex;
    gap: 2rem;
    justify-content: center;
  }

  #Banner-{{ section.id }} .button--primary {
    background-color: var(--pw-accent) !important;
    color: var(--pw-text) !important;
    padding: 1.5rem 4rem !important;
    font-size: 1.6rem !important;
    font-weight: 600 !important;
    border-radius: 50px !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  #Banner-{{ section.id }} .button--secondary {
    background-color: transparent !important;
    border: 1px solid var(--pw-accent) !important;
    color: var(--pw-accent) !important;
    padding: 1.5rem 4rem !important;
    font-size: 1.6rem !important;
    font-weight: 600 !important;
    border-radius: 50px !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @keyframes fadeInLift {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 749px) {
    #Banner-{{ section.id }} {
      min-height: 60vh;
      padding: 4rem 2rem;
    }
    #Banner-{{ section.id }} .banner__heading {
      font-size: 3.5rem !important;
    }
    #Banner-{{ section.id }} .banner__text {
      font-size: 1.6rem !important;
    }
    #Banner-{{ section.id }} .banner__buttons {
      flex-direction: column;
      gap: 1.5rem;
    }
  }
{%- endstyle -%}

<div id="Banner-{{ section.id }}" class="banner">
  <div class="banner__content page-width">
    <div class="banner__box">
      <h2 class="banner__heading">Nature's Path To Stronger Hair</h2>
      <div class="banner__text">
        <p>Premium botanical oils crafted to nourish roots, strengthen strands and support healthier-looking hair.</p>
      </div>
      <div class="banner__buttons">
        <a href="/collections/all" class="button button--primary">Shop Now</a>
        <a href="/pages/about-us" class="button button--secondary">Learn More</a>
      </div>
    </div>
  </div>
</div>
                <a
                  {% if block.settings.button_link_2 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_2 }}"
                  {% endif %}
                  class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{- block.settings.button_label_2 | escape -}}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

