{%- style -%}
  .benefits {
    background-color: #F8F6F1;
    padding: 8rem 0;
  }

  .benefits__heading {
    font-family: var(--pw-font-heading);
    color: var(--pw-primary);
    font-size: 4rem;
    text-align: center;
    margin-bottom: 5rem;
  }

  .benefits__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .benefit-card {
    background: #ffffff;
    padding: 4rem 3rem;
    border-radius: 12px;
    text-align: center;
    transition: all 0.4s ease;
    border: 1px solid rgba(232, 223, 200, 0.3);
  }

  .benefit-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(35, 78, 63, 0.08);
    border-color: var(--pw-accent);
  }

  .benefit-card svg {
    width: 48px;
    height: 48px;
    color: var(--pw-primary);
    margin-bottom: 2.5rem;
  }

  .benefit-card h3 {
    font-family: var(--pw-font-heading);
    color: var(--pw-primary);
    font-size: 2.4rem;
    margin-bottom: 1.5rem;
  }

  .benefit-card p {
    font-family: var(--pw-font-body);
    color: var(--pw-text);
    font-size: 1.6rem;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .benefits {
      padding: 5rem 0;
    }
    .benefits__heading {
      font-size: 3rem;
      margin-bottom: 3rem;
    }
    .benefits__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
{%- endstyle -%}

