{%- style -%}
  .trust-bar {
    background-color: #E8DFC8;
    padding: 3.5rem 0;
    border-bottom: 1px solid rgba(35, 78, 63, 0.05);
  }

  .trust-bar__wrapper {
    display: flex;
    justify-content: space-around;
    align-items: center;
    gap: 3rem;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .trust-item svg {
    width: 20px;
    height: 20px;
    color: #234E3F;
    stroke-width: 1px !important;
  }

  .trust-item span {
    font-family: var(--pw-font-body);
    font-size: 1.1rem;
    font-weight: 400;
    color: #234E3F;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  @media screen and (max-width: 989px) {
    .trust-bar__wrapper {
      flex-wrap: wrap;
      justify-content: center;
      gap: 3rem 5rem;
    }
  }
{%- endstyle -%}

<div class="trust-bar">
